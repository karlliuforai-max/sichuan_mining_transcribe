.DS_Store
__pycache__/
*.pyc
.venv/
sichuan-mining-transcribe/.venv/

# Local dev tooling (codegraph index, MCP / Claude Code config) — machine-specific.
.codegraph/
.claude/
.mcp.json

# Real meeting source files and generated transcript/minutes outputs may contain
# sensitive business content. Keep only placeholder files in git.
转写源/
sichuan-mining-transcribe/outputs/**
!sichuan-mining-transcribe/outputs/.gitkeep

# Knowledge base (glossary, rules, candidates) travels WITH the skill on purpose,
# so it is intentionally NOT ignored — deploying the skill carries learned corrections.

# Raw meeting transcripts dropped into the skill dir stay local.
sichuan-mining-transcribe/*.txt
!sichuan-mining-transcribe/requirements.txt
sichuan-mining-transcribe/*.pdf

# Local environment files and secrets.
.env
.env.*
!.env.example
*.key
